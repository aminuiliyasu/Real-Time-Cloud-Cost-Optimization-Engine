# Copy to .env and fill in secret values locally (never commit .env).

APP_ENV=development
API_KEY=change-me-to-a-random-string
API_PORT=8000
POSTGRES_PASSWORD=postgres
POSTGRES_URL=postgresql://postgres:postgres@localhost:55432/cost_optimizer
REDIS_URL=redis://localhost:56379/0

# AWS — comma-separated profile:region pairs for multi-account ingestion
AWS_REGION=af-south-1
AWS_PROFILE=default
AWS_PROFILES=default:af-south-1,rhentify-aws:us-east-1

# GCP — comma-separated project:zone pairs (optional; needs gcloud auth or GOOGLE_APPLICATION_CREDENTIALS)
GCP_PROJECTS=my-gcp-project:us-central1-a,other-project:europe-west1-b
GCP_DEFAULT_ZONE=us-central1-a
